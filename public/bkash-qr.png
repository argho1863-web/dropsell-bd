<svg xmlns="http://www.w3.org/2000/svg" width="300" height="300" viewBox="0 0 300 300">
  <rect width="300" height="300" fill="#fff"/>
  <rect x="10" y="10" width="280" height="280" rx="12" fill="#fce7f3" stroke="#fbcfe8" stroke-width="2"/>
  <!-- QR border decoration -->
  <rect x="30" y="30" width="60" height="60" rx="4" fill="none" stroke="#db2777" stroke-width="4"/>
  <rect x="38" y="38" width="20" height="20" rx="2" fill="#db2777"/>
  <rect x="210" y="30" width="60" height="60" rx="4" fill="none" stroke="#db2777" stroke-width="4"/>
  <rect x="218" y="38" width="20" height="20" rx="2" fill="#db2777"/>
  <rect x="30" y="210" width="60" height="60" rx="4" fill="none" stroke="#db2777" stroke-width="4"/>
  <rect x="38" y="218" width="20" height="20" rx="2" fill="#db2777"/>
  <!-- Pattern dots -->
  <rect x="110" y="30" width="10" height="10" fill="#db2777"/>
  <rect x="130" y="30" width="10" height="10" fill="#db2777"/>
  <rect x="150" y="30" width="10" height="10" fill="#db2777"/>
  <rect x="110" y="50" width="10" height="10" fill="#db2777"/>
  <rect x="150" y="50" width="10" height="10" fill="#db2777"/>
  <rect x="110" y="70" width="10" height="10" fill="#db2777"/>
  <rect x="130" y="70" width="10" height="10" fill="#db2777"/>
  <rect x="150" y="70" width="10" height="10" fill="#db2777"/>
  <!-- Center area -->
  <rect x="100" y="100" width="100" height="100" rx="8" fill="#db2777"/>
  <text x="150" y="158" text-anchor="middle" font-family="sans-serif" font-size="36" font-weight="bold" fill="white">b</text>
  <!-- Bottom text -->
  <text x="150" y="285" text-anchor="middle" font-family="sans-serif" font-size="13" fill="#9d174d" font-weight="600">Scan to Pay via bKash</text>
</svg>
